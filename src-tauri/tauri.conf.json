{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ComfyUI Patcher",
  "version": "0.1.9",
  "identifier": "com.example.comfyui-patcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ComfyUI Patcher",
        "width": 1440,
        "height": 940,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENENjgxNzRCODgxQzk3NEYKUldSUGx4eUlTeGRvelFXTlZpLzR4dW9CY1BYeG9aQlBIV2NYVWNkY1lhb3Ywa2JKcW4wVFNNUHkK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
